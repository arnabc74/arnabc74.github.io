                         align=middle>
                         
                          d<sub>i</sub><sup>2</sup> /
   n(n<sup>2</sup> - 1))
   </blockquote>
   
   
   </td></tr></table>
   </blockquote>
   
<p>
   <table><tr><td width=2 bgcolor="#cc0000"></td>
   <td>
   <b><font color="#cc0000">
   Exercise RCORR.2:</font></b> 
   
