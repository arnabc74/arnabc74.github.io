  [          { "nota":false,       "question": "$(1+2i)-(4-5i)(2+i)=?$",       "options": [                    "$8i-12$"           ,           "$8i+12$"           ,           "$12i-8$"           ,           "$4i-6$"                  ],       "ans": 0,       "marks": 10,       "explanation": " $\\begin{eqnarray} (1+2i) - (4-5i)(2+i)  &=& (1+2i) - \\big(8 + 4i - 10i - 5i^2\\big) \\\\ &=& (1+2i) - \\big(8 + 4i - 10i + 5\\big) \\\\ &=& (1+2i) - (13 - 6i) \\\\ &=& 1 + 2i - 13 + 6i \\\\ &=& -12 + 8i \\end{eqnarray}$ "     }     ,     { "nota":false,       "question": "$\\frac{1+2i}{1+i}+2(3+4i)=?$",       "options": [                    "$\\frac 12(15+17i).$"           ,           "$\\frac 13(15+17i).$"           ,           "$\\frac 12(17+15i).$"           ,           "$\\frac 12(15-17i).$"                  ],       "ans": 0,       "marks": 10,       "explanation": " $\\begin{eqnarray} \\frac{1+2i}{1+i} + 2(3+4i) &=& \\frac{(1+2i)(1-i)}{(1+i)(1-i)} + (6+8i) \\\\ &=& \\frac{1 - i + 2i - 2i^2}{1 - i^2} + 6 + 8i \\\\ &=& \\frac{1 + i + 2}{2} + 6 + 8i \\\\ &=& \\frac{3 + i}{2} + 6 + 8i \\\\ &=& \\frac{3}{2} + \\frac{i}{2} + 6 + 8i \\\\ &=& \\frac{15}{2} + \\frac{17}{2}i \\end{eqnarray}$ "     }     ,     { "nota":true,       "question": "$\\frac{1+2i}{2(1+i)+3i}=?$",       "options": [                    "$\\frac{12-i}{29}.$"           ,           "$\\frac{12-i}{30}.$"           ,           "$\\frac{12+i}{29}.$"           ,           "এদের কোনোটাই নয়৷"                  ],       "ans": 0,       "marks": 10,       "explanation": " $\\begin{eqnarray} \\frac{1+2i}{2(1+i)+3i} &=& \\frac{1+2i}{2 + 2i + 3i} \\\\ &=& \\frac{1+2i}{2 + 5i} \\\\ &=& \\frac{(1+2i)(2-5i)}{(2+5i)(2-5i)} \\\\ &=& \\frac{2 - 5i + 4i - 10i^2}{4 - 25i^2} \\\\ &=& \\frac{2 - i + 10}{4 + 25} \\\\ &=& \\frac{12 - i}{29} \\\\ &=& \\frac{12}{29} - \\frac{1}{29}i \\end{eqnarray}$ "     }     ,     { "nota":true,       "question": "$i(2(3-i)+\\overline{4+2i})(i-1).$",       "options": [                    "$-14+6i$"           ,           "$14-6i$"           ,           "$10-6i$"           ,           "এদের কোনোটাই নয়৷"                  ],       "ans": 0,       "marks": 10,       "explanation": " $\\begin{eqnarray} i\\big(2(3-i) + \\overline{(4+2i)}(i-1)\\big) &=& i\\big(6 - 2i + (4-2i)(i-1)\\big) \\\\ &=& i\\big(6 - 2i + (4i - 4 - 2i^2 + 2i)\\big) \\\\ &=& i\\big(6 - 2i + (4i - 4 + 2 + 2i)\\big) \\\\ &=& i\\big(6 - 2i + (-2 + 6i)\\big) \\\\ &=& i(4 + 4i) \\\\ &=& 4i + 4i^2 \\\\ &=& 4i - 4 \\end{eqnarray}$ "     }     ,     { "nota":false,       "question": "যদি $z=2+3i$  আর $w = 1/(1+i)$  হয়, $(2z-w)w=?$",       "options": [                    "$5+\\frac 32i.$"           ,           "$5-\\frac 32i.$"           ,           "$5+3i.$"           ,           "$3+5i.$"                  ],       "ans": 0,       "marks": 10,       "explanation": " $\\begin{eqnarray} (2z - w)w &=& \\left(2(2+3i) - \\frac{1}{1+i}\\right)\\frac{1}{1+i} \\\\ &=& \\left(4+6i - \\frac{1-i}{2}\\right)\\frac{1-i}{2} \\\\ &=& \\left(\\frac{8+12i - (1-i)}{2}\\right)\\frac{1-i}{2} \\\\ &=& \\frac{7+13i}{2} \\cdot \\frac{1-i}{2} \\\\ &=& \\frac{(7+13i)(1-i)}{4} \\\\ &=& \\frac{7 - 7i + 13i - 13i^2}{4} \\\\ &=& \\frac{7 + 6i + 13}{4} \\\\ &=& \\frac{20 + 6i}{4} \\\\ &=& 5 + \\frac{3}{2}i \\end{eqnarray}$ "     }        ]     