const http = require('http');
const fs = require('fs');
const path = require('path');

const PORT = 3000;
const PUBLIC_DIR = path.join(process.cwd(), 'public');

// MIME types map helps the browser understand what kind of file is being sent.
const MIME_TYPES = {
    '.html': 'text/html',
    '.js': 'text/javascript',
    '.css': 'text/css',
    '.png': 'image/png',
    '.jpg': 'image/jpeg',
    '.gif': 'image/gif',
    '.svg': 'image/svg+xml',
};

const server = http.createServer((req, res) => {
    const { url, method } = req;

    // 1. Handle specific API GET requests
    if (method === 'GET') {
        console.log('req.url = ['+req.url+']')
        console.log('req.headers.host = ['+req.headers.host+']')
        const myURL = new URL(req.url, 'http://' + req.headers.host);
        const dir = myURL.searchParams.get('dir')
        console.log('dir = ['+dir+']')
        idir = new Number(dir)
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ location: 2*idir-1, timestamp: Date.now() }));
        return; // Stop further execution
    }

    // 2. Serve static files
    // Determine the file path; default to index.html for root URL.
    let filePath = path.join(PUBLIC_DIR, url === '/' ? 'index.html' : url);
    
    // Ensure path traversal is not possible for security.
    const pathTraversal = !filePath.startsWith(PUBLIC_DIR);

    if (pathTraversal) {
        res.writeHead(404, { 'Content-Type': 'text/plain' });
        res.end('404: Not Found');
        return;
    }

    fs.readFile(filePath, (err, data) => {
        if (err) {
            // Serve a custom 404 page if desired, or a plain message
            res.writeHead(404, { 'Content-Type': 'text/plain' });
            res.end('404: File Not Found');
        } else {
            const ext = path.extname(filePath);
            const contentType = MIME_TYPES[ext] || MIME_TYPES['.html']; // Default to html if unknown

            res.writeHead(200, { 'Content-Type': contentType });
            res.end(data);
        }
    });
});

server.listen(PORT, () => {
    console.log(`Server running at http://localhost:${PORT}/`);
});

