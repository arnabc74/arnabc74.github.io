doit = function(theta) {
    theta = theta*pi/180
  u<<-c(cos(theta),sin(theta))
  v<<-c(-sin(theta),cos(theta))
pval = dat%*%u
varValue = var(pval)
feet = pval%*%t(u)
  bareplot(dat,xlim=c(-12,12),ylim=c(-12,12),asp=1,pch=20,col='blue',cex=2,main=varValue)

